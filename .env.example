# Public site URL
# Local: http://localhost:3000
# Vercel Preview: set in Vercel Environment Variables after the Preview URL/custom preview domain is verified.
# Vercel Production: set in Vercel Environment Variables after the production URL/custom domain is verified.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — Phase 3 preparation only.
# These placeholders define the contract; no real Supabase client/Auth/Storage code is active yet.
# Do not add real values until the Supabase/Auth strategy is approved.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only secret.
# Never expose this value to client components, browser code, static JSON, public config, or NEXT_PUBLIC_* variables.
# Add a real value only in local .env.local and Vercel Environment Variables when server-side Supabase tasks begin.
SUPABASE_SERVICE_ROLE_KEY=

# Future Phase 3/4 notes:
# - Auth/MFA provider settings will be added only after the user approves the auth strategy.
# - Storage bucket names and upload limits will be documented before implementation.
# - RLS policies must be designed before any production data is written.
